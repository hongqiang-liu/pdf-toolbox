{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "pdf_toolbox",
  "version": "0.1.0",
  "identifier": "com.example.pdf-toolbox",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PDF Toolbox",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "PDF split, merge, text extraction and image export tool",
    "longDescription": "A cross-platform PDF toolbox powered by Rust, Tauri and PDFium.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        }
      }
    }
  }
}
